#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PKG_MGR="pnpm"

if ! command -v pnpm >/dev/null 2>&1; then
  PKG_MGR="npm"
fi

if [[ ! -d "${SCRIPT_DIR}/node_modules" ]]; then
  echo "Installing dependencies..."
  if [[ "${PKG_MGR}" == "pnpm" ]]; then
    pnpm --dir "${SCRIPT_DIR}" install --frozen-lockfile
  else
    npm --prefix "${SCRIPT_DIR}" install
  fi
fi

NEEDS_BUILD=0
if [[ ! -f "${SCRIPT_DIR}/dist/cli.js" ]]; then
  NEEDS_BUILD=1
elif [[ "${SCRIPT_DIR}/src/cli.ts" -nt "${SCRIPT_DIR}/dist/cli.js" ]]; then
  NEEDS_BUILD=1
elif [[ "${SCRIPT_DIR}/package.json" -nt "${SCRIPT_DIR}/dist/cli.js" ]]; then
  NEEDS_BUILD=1
elif [[ "${SCRIPT_DIR}/tsconfig.json" -nt "${SCRIPT_DIR}/dist/cli.js" ]]; then
  NEEDS_BUILD=1
elif [[ -f "${SCRIPT_DIR}/pnpm-lock.yaml" && "${SCRIPT_DIR}/pnpm-lock.yaml" -nt "${SCRIPT_DIR}/dist/cli.js" ]]; then
  NEEDS_BUILD=1
fi

if [[ "${NEEDS_BUILD}" -eq 1 ]]; then
  echo "Building TypeScript sources..."
  if [[ "${PKG_MGR}" == "pnpm" ]]; then
    pnpm --dir "${SCRIPT_DIR}" build
  else
    npm --prefix "${SCRIPT_DIR}" run build
  fi
fi

exec node "${SCRIPT_DIR}/dist/cli.js" "$@"
