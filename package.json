{
  "name": "gh-activity-viz",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub CLI extension for commit activity visualizations with interactive TUI and grouped metrics",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gh-activity-viz": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "neo-blessed": "^0.2.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
